# ============================================================================
# MPRVVN — environment variables. Copy to `.env` and fill in. NEVER commit .env.
# ============================================================================

# ====== PostgreSQL (use YOUR database — Neon, RDS, Cloud SQL, self-hosted…) ===
# DATABASE_URL = pooled/runtime connection. DIRECT_URL = direct connection used
# by `prisma migrate`. For a non-pooled Postgres, set both to the same URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ====== Auth.js (NextAuth v5) ================================================
# Generate a strong secret:  npx auth secret
AUTH_SECRET=""
# Keep true behind a reverse proxy / load balancer that terminates TLS.
AUTH_TRUST_HOST="true"

# ====== Public site URL (build-time; used for canonical/OG/sitemap) ==========
# MUST be the public production origin, e.g. https://www.mprvvn.gov.in
NEXT_PUBLIC_SITE_URL="https://mprvvn.vercel.app"

# ====== First admin account ==================================================
# Only needed when running `npm run db:seed` (fresh DB) or `npm run create-admin`.
# Do NOT keep these set in the long-running production environment.
# Use a strong password (>= 12 chars).
ADMIN_EMAIL="admin@example.gov.in"
ADMIN_PASSWORD="change-this-to-a-strong-password"
